    collectedLetters = {}
    codeString       = ""
    collectedSession = {}
    updateDisplay()
end)

-- Manual drag
local dragging, dragStart, startPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging  = true
        dragStart = input.Position
        startPos  = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMove then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- ────────────────────────────────────────
-- Letter extraction + filter
-- ────────────────────────────────────────
local function extractLetter(obj)
    local child = obj:FindFirstChild(LETTER_CHILD)
        or obj:FindFirstChildWhichIsA("StringValue")
    if child and child:IsA("StringValue") then
        return child.Value:sub(1,1):upper()
    end
    -- Fallback: scan all StringValues inside the box
    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("StringValue") and #v.Value == 1 then
            return v.Value:upper()
        end
    end
    return nil
end

local function isTargetLetter(letter)
    return letter and TARGET_LETTERS[letter] == true
end

local function registerLetter(letter)
    table.insert(collectedLetters, letter)
    codeString = table.concat(collectedLetters, "")
    updateDisplay()
end

-- ────────────────────────────────────────
-- Force drop rate on your own game
-- Directly sets the StringValue on the box
-- to a needed letter before collecting
-- Works because this is your own game / Studio
-- ────────────────────────────────────────
local function getNeededLetters()
    local have = {}
    for _, l in ipairs(collectedLetters) do
        have[l] = (have[l] or 0) + 1
    end
    local needed = {}
    for letter in pairs(TARGET_LETTERS) do
        table.insert(needed, letter)
    end
    return needed
end

local function forceLetterOnBox(obj)
    -- Find the StringValue inside the box and overwrite it
    local child = obj:FindFirstChild(LETTER_CHILD)
        or obj:FindFirstChildWhichIsA("StringValue")

    if child and child:IsA("StringValue") then
        local needed = getNeededLetters()
        if #needed > 0 then
            -- Pick a random needed letter
            local pick = needed[math.random(1, #needed)]
            pcall(function()
                child.Value = pick  -- direct write, own game only
            end)
            return pick
        end
    end
    return nil
end

-- ────────────────────────────────────────
-- Collection
-- ────────────────────────────────────────
local function collectObject(obj)
    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            pcall(fireproximityprompt, v)
            return
        end
    end
    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("ClickDetector") then
            pcall(fireclickdetector, v)
            return
        end
    end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local target = obj:IsA("Model") and obj.PrimaryPart or obj
        if target then pcall(firetouchinterest, root, target, 0) end
    end
end

-- ────────────────────────────────────────
-- Spawn watcher
-- ────────────────────────────────────────
local function registerBox(obj)
    if trackedBoxes[obj] then return end
    trackedBoxes[obj] = true
    obj.AncestryChanged:Connect(function(_, parent)
        if not parent then trackedBoxes[obj] = nil end
    end)
end

for _, obj in ipairs(workspace:GetDescendants()) do
    if (function()
        local n = obj.Name:lower()
        for _, name in ipairs(BOX_NAMES) do
            if n:find(name:lower()) then return true end
        end
    end)() then registerBox(obj) end
end

workspace.DescendantAdded:Connect(function(obj)
    local n = obj.Name:lower()
    for _, name in ipairs(BOX_NAMES) do
        if n:find(name:lower()) then
            registerBox(obj)
            return
        end
    end
end)

-- ────────────────────────────────────────
-- Main loop
-- ────────────────────────────────────────
RunService.Heartbeat:Connect(function()
    if not collecting then return end
    local now = tick()
    if (now - lastTick) < INTERVAL then return end
    lastTick = now

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local rootPos = root.Position

    for obj in pairs(trackedBoxes) do
        if not collectedSession[obj] then
            local ok, pos = pcall(function()
                if obj:IsA("Model") and obj.PrimaryPart then
                    return obj.PrimaryPart.Position
                elseif obj:IsA("BasePart") then
                    return obj.Position
                end
            end)
            if ok and pos and (rootPos - pos).Magnitude <= RADIUS then
                -- Force a needed letter onto the box before collecting
                local forced = forceLetterOnBox(obj)
                local letter = forced or extractLetter(obj)

                pcall(collectObject, obj)
                collectedSession[obj] = true

                if letter and isTargetLetter(letter) then
                    registerLetter(letter)
                end
            end
        end
    end
end)

player.CharacterAdded:Connect(function(char)
    char:WaitForChild("HumanoidRootPart")
end)
