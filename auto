local function updateDisplay()
    codeLabel.Text  = "Code: " .. (codeString ~= "" and codeString or "—")
    countLabel.Text = "Letters: " .. #collectedLetters .. " / 10"

    -- Cross off collected letters from needed display
    local remaining = {}
    local have = {}
    for _, l in ipairs(collectedLetters) do have[l] = true end
    for letter in pairs(TARGET_LETTERS) do
        if not have[letter] then
            table.insert(remaining, letter)
        end
    end
    table.sort(remaining)
    neededLabel.Text = #remaining > 0
        and "Need: " .. table.concat(remaining, " ")
        or  "All letters collected!"
end

