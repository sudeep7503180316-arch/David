-- ══════════════════════════════════════
-- STATE
-- ══════════════════════════════════════
local autoLockEnabled = false
local targetLuck = CONFIG.DefaultLuck
local lastAppliedLuck = nil

-- ══════════════════════════════════════
-- CORE APPLY FUNCTION
-- ══════════════════════════════════════
local function applyLuck(value)
    local stat = findLuckStat()
    if not stat then
        statusLabel.Text = "⚠ Stat '" .. CONFIG.LuckStatName .. "' not found."
        statusLabel.TextColor3 = Color3.fromRGB(255, 160, 60)
        return false
    end

    local clamped = math.clamp(value, CONFIG.MinLuck, CONFIG.MaxLuck)

    -- Try Value property (IntValue / NumberValue)
    if stat:IsA("IntValue") or stat:IsA("NumberValue") then
        stat.Value = clamped
        lastAppliedLuck = clamped
        return true
    end

    -- Try StringValue (some games store as string)
    if stat:IsA("StringValue") then
        stat.Value = tostring(clamped)
        lastAppliedLuck = clamped
        return true
    end

    statusLabel.Text = "⚠ Unsupported stat type: " .. stat.ClassName
    statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    return false
end

local function readCurrentLuck()
    local stat = findLuckStat()
    if not stat then return nil end
    local v = tonumber(stat.Value)
    return v
end

-- ══════════════════════════════════════
-- BUTTON LOGIC
-- ══════════════════════════════════════
applyBtn.MouseButton1Click:Connect(function()
    local input = tonumber(inputBox.Text)
    if not input then
        statusLabel.Text = "⚠ Invalid number."
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    targetLuck = math.clamp(input, CONFIG.MinLuck, CONFIG.MaxLuck)
    local success = applyLuck(targetLuck)

    if success then
        statusLabel.Text = "✔ Luck set to " .. tostring(targetLuck)
        statusLabel.TextColor3 = Color3.fromRGB(100, 220, 130)
    end
end)

lockBtn.MouseButton1Click:Connect(function()
    autoLockEnabled = not autoLockEnabled
    if autoLockEnabled then
        lockBtn.Text = "🔒 AUTO: ON"
        lockBtn.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
        statusLabel.Text = "Auto-lock active."
        statusLabel.TextColor3 = Color3.fromRGB(100, 220, 130)
    else
        lockBtn.Text = "🔓 AUTO: OFF"
        lockBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        statusLabel.Text = "Auto-lock disabled."
        statusLabel.TextColor3 = Color3.fromRGB(160, 160, 180)
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

-- ══════════════════════════════════════
-- HEARTBEAT LOOP
-- Updates display + re-applies if auto-lock on
-- ══════════════════════════════════════
local elapsed = 0
RunService.Heartbeat:Connect(function(dt)
    elapsed = elapsed + dt
    if elapsed < CONFIG.UpdateInterval then return end
    elapsed = 0

    local current = readCurrentLuck()
    if current ~= nil then
        currentLabel.Text = "Current Luck: " .. tostring(current)
    else
        currentLabel.Text = "Current Luck: (stat not found)"
    end

    if autoLockEnabled then
        local input = tonumber(inputBox.Text)
        if input then
            targetLuck = math.clamp(input, CONFIG.MinLuck, CONFIG.MaxLuck)
        end
        if current ~= targetLuck then
            applyLuck(targetLuck)
        end
    end
end)
