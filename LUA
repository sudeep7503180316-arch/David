local LocalPlayer = Players.LocalPlayer

-- ══════════════════════════════════════
-- CONFIG
-- ══════════════════════════════════════
local CONFIG = {
    DefaultLuck = 100,
    MinLuck = 0,
    MaxLuck = 999999,
    LuckStatName = "Luck", -- change to match your game's stat name
    UpdateInterval = 0.1,  -- seconds between luck re-applies
}

-- ══════════════════════════════════════
-- STAT RESOLVER
-- Tries common stat locations in order
-- ══════════════════════════════════════
local function findLuckStat()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local s = leaderstats:FindFirstChild(CONFIG.LuckStatName)
        if s then return s end
    end

    local statsFolder = LocalPlayer:FindFirstChild("Stats")
        or LocalPlayer:FindFirstChild("Data")
        or LocalPlayer:FindFirstChild("PlayerData")
    if statsFolder then
        local s = statsFolder:FindFirstChild(CONFIG.LuckStatName)
        if s then return s end
    end

    -- Deep search fallback
    for _, child in ipairs(LocalPlayer:GetChildren()) do
        local s = child:FindFirstChild(CONFIG.LuckStatName)
        if s then return s end
    end

    return nil
end

